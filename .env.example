# Copia este archivo a .env.local y pon tus propias claves de Supabase
# (Project Settings → API en tu proyecto de supabase.com).
# La "anon/publishable key" es segura para el navegador: la seguridad real
# la da Row Level Security (RLS), no el secreto de esta clave.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
